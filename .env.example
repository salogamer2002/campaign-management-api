# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Database (SQLite path — on Render, set to persistent disk path)
DB_PATH=./data/campaigns.db

# CORS — comma-separated origins for production
# Example: https://campaign-dashboard.vercel.app,https://creative-brief.vercel.app
CORS_ORIGIN=*
