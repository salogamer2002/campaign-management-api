# Server
PORT=3002
NODE_ENV=development

# Campaign Management API connection
# On Render: https://campaign-management-api-xxxx.onrender.com/api
CAMPAIGN_API_URL=http://localhost:3000/api
CAMPAIGN_API_TOKEN=

# Alert engine polling interval
POLL_INTERVAL_MS=30000

# CORS — comma-separated origins for production
CORS_ORIGIN=*

# Database path (SQLite)
DB_PATH=./data/notifications.db
